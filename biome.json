{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "axon/src/**/*.ts",
      "axon/src/**/*.tsx",
      "axon/src/**/*.js",
      "axon/src/**/*.jsx",
      "axon/src/**/*.json",
      "axon/test/**/*.ts",
      "axon/test/**/*.tsx",
      "axon/test/**/*.js",
      "axon/test/**/*.jsx",
      "axon/test/**/*.json",
      "!**/node_modules",
      "!research",
      "!vendor",
      "!data",
      "!docs",
      "!axon/bin",
      "!axon/node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
