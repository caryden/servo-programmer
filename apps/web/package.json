{
  "name": "@axon/web-poc",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build ./src/index.ts --target browser --format esm --outdir ./dist",
    "check": "bun x @biomejs/biome check src package.json index.html",
    "test": "playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "bun run build && python3 -m http.server 8765",
    "start": "bun run build && python3 -m http.server 8765",
    "live": "bun run build && bun run ./server.ts"
  },
  "dependencies": {
    "@axon/core": "workspace:*",
    "@axon/transport-webhid": "workspace:*",
    "@axon/ui": "workspace:*",
    "aes-js": "^3.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
