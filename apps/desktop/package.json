{
  "name": "@axon/desktop-poc",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "bun x @biomejs/biome check src scripts package.json electrobun.config.ts",
    "clean": "rm -rf build artifacts",
    "build": "electrobun build --env=dev",
    "build:canary": "electrobun build --env=canary",
    "build:stable": "electrobun build --env=stable",
    "package": "electrobun build --env=stable",
    "start": "electrobun dev",
    "dev": "electrobun dev --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@axon/core": "workspace:*",
    "@axon/transport-nodehid": "workspace:*",
    "@axon/ui": "workspace:*",
    "electrobun": "1.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "latest",
    "@types/three": "^0.180.0",
    "typescript": "^5.9.3"
  }
}
