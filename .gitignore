# Vendor binaries — downloaded by the user, not owned by this repo.
# Re-download with the URLs in docs/FINDINGS.md.
downloads/

# Local scratch workspace for captures, generated probes, and agent output.
tmp/

# Scratch files from static analysis
*.strings.txt
*.bin
/ID_10_*
/strings_*.txt
/tform1_*.txt
/unit_names.txt

# But DO commit the decrypted firmware plaintexts under research/ —
# they're useful as ground truth for the SFW decrypter port (issue #11)
# and small enough to live in git.
!research/decrypted-firmware/*.plain.bin

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
ENV/

# Node / Bun
node_modules/
*.log

# Capture files (large binary data)
captures/*.sal
captures/*.csv
captures/*.hex
captures/*.sr
!captures/.gitkeep

# Large binary Saleae session files (>100 MB GitHub limit).
# The decoded Async Serial CSV exports are small enough to commit
# and contain everything we need from each capture — see
# research/static-analysis/decode_saleae_csv.py for the parser.
research/saleae-captures/Session 0.sal

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Conductor workspace
.context/
