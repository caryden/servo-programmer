{
  "name": "axon",
  "version": "0.1.0-dev",
  "description": "Cross-platform CLI for Axon Robotics servo programmer. Replacement for the Windows-only vendor exe.",
  "type": "module",
  "private": true,
  "bin": {
    "axon": "./src/cli.ts"
  },
  "scripts": {
    "axon": "bun run src/cli.ts",
    "build": "bun build --compile --outfile=./bin/axon ./src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "node-hid": "^3.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
